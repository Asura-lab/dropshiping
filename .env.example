# ─── Database ────────────────────────────────────────────────────────────────
# Local Docker only
POSTGRES_USER="dropship"
POSTGRES_PASSWORD="change-me-local-only"
POSTGRES_DB="dropshipping_dev"

# Railway: copy from Railway PostgreSQL service → "Connect" tab
DATABASE_URL="postgresql://user:password@localhost:5432/dropshipping_dev"

# ─── Redis ───────────────────────────────────────────────────────────────────
# Railway: copy from Railway Redis service → "Connect" tab
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
# Production: set to your Vercel domain, e.g. https://shuud.vercel.app
FRONTEND_URL="http://localhost:3000"

# ─── QPay ────────────────────────────────────────────────────────────────────
# Production: get from QPay merchant portal
QPAY_MERCHANT_ID=""
QPAY_MERCHANT_KEY=""
QPAY_INVOICE_CODE=""
# Production: https://your-railway-domain.up.railway.app/v1/payments/qpay/callback
QPAY_CALLBACK_URL="http://localhost:4000/v1/payments/qpay/callback"

# ─── SMS (Mongolian SMS API) ─────────────────────────────────────────────────
# Providers: MobiCom, Unitel — get API key from your SMS provider
SMS_API_KEY=""
SMS_SENDER_ID="Delguur"

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# R2 → Manage R2 API Tokens → Create token (Object Read & Write)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="dropshipping-images"
# Found in R2 dashboard: Account ID
R2_ACCOUNT_ID=""
# R2 → Your bucket → Settings → Public Access → Custom domain or r2.dev URL
R2_PUBLIC_URL=""

# ─── Next.js (apps/web) ──────────────────────────────────────────────────────
# Production: your Railway API URL, e.g. https://shuud-api.up.railway.app/v1
NEXT_PUBLIC_API_URL="http://localhost:4000/v1"
