# ─── Database ────────────────────────────────────────────────────────────────
# Local Docker only
POSTGRES_USER="dropship"
POSTGRES_PASSWORD="change-me-local-only"
POSTGRES_DB="dropshipping_dev"

# Railway: copy from Railway PostgreSQL service → "Connect" tab
DATABASE_URL="postgresql://user:password@localhost:5432/dropshipping_dev"

# ─── Redis ───────────────────────────────────────────────────────────────────
# Railway: copy from Railway Redis service → "Connect" tab
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
# Comma-separated list of allowed CORS origins
# Dev default: localhost:3000 (web) + localhost:3500 (admin) are allowed automatically
# Production: "https://shuud.vercel.app,https://admin.shuud.vercel.app"
FRONTEND_URL="http://localhost:3000,http://localhost:3500"

# ─── QPay ────────────────────────────────────────────────────────────────────
# Production: get from QPay merchant portal
QPAY_MERCHANT_ID=""
QPAY_MERCHANT_KEY=""
QPAY_INVOICE_CODE=""
# Production: https://your-railway-domain.up.railway.app/v1/payments/qpay/callback
QPAY_CALLBACK_URL="http://localhost:4000/v1/payments/qpay/callback"

# ─── SocialPay ───────────────────────────────────────────────────────────────
# Production: get from SocialPay merchant portal (https://socialpay.mn)
# Leave empty → dev mock mode (auto-confirms immediately)
SOCIALPAY_TERMINAL=""
SOCIALPAY_KEY=""
# Base URL used for SocialPay callback (must be publicly accessible)
API_BASE_URL="http://localhost:4000"

# ─── SMS (Mongolian SMS API) ─────────────────────────────────────────────────
# Providers: MobiCom, Unitel — get API key from your SMS provider
SMS_API_KEY=""
SMS_SENDER_ID="Delguur"

# ─── Amazon Product Advertising API ──────────────────────────────────────────
# 1. Amazon Associates бүртгэл: https://affiliate-program.amazon.com
# 2. Баталгаажсаны дараа: Tools → Product Advertising API → Manage credentials
# Leave empty → dev mock mode ажиллана (бодит API дуудахгүй)
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""
AMAZON_PARTNER_TAG=""            # e.g. yourstore-20
AMAZON_MARKETPLACE="www.amazon.com"
AMAZON_REGION="us-east-1"

# ─── Scraper ──────────────────────────────────────────────────────────────────
# ScraperAPI: https://www.scraperapi.com (free tier: 1000 req/month)
# Leave empty to use dev mock mode (returns fake product data)
SCRAPER_API_KEY=""

# ─── Webhook Security ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by /internal/source-orders/webhook — Amazon SP-API sends this in X-Webhook-Secret header
WEBHOOK_SECRET=""

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# R2 → Manage R2 API Tokens → Create token (Object Read & Write)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="dropshipping-images"
# Found in R2 dashboard: Account ID
R2_ACCOUNT_ID=""
# R2 → Your bucket → Settings → Public Access → Custom domain or r2.dev URL
R2_PUBLIC_URL=""

# ─── Next.js (apps/web + apps/admin) ────────────────────────────────────────
# Production: your Railway API URL, e.g. https://shuud-api.up.railway.app/v1
NEXT_PUBLIC_API_URL="http://localhost:4000/v1"
