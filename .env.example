# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/dropshipping_dev"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ─── QPay ────────────────────────────────────────────────────────────────────
QPAY_MERCHANT_ID=""
QPAY_MERCHANT_KEY=""
QPAY_INVOICE_CODE=""
QPAY_CALLBACK_URL="http://localhost:4000/v1/payments/qpay/callback"

# ─── SMS (Mongolian SMS API) ─────────────────────────────────────────────────
SMS_API_KEY=""
SMS_SENDER_ID="Delguur"

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="dropshipping-images"
R2_ACCOUNT_ID=""
R2_PUBLIC_URL=""

# ─── Next.js (apps/web) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/v1"
